policy "permit-clinician-read-patient"
permit
  action == "readPatient";
  resource == "patient";
  <jwt.token>.payload.user_role == "CLINICIAN";
obligation
  {
    "type": "filterJsonContent",
    "actions": [
      {
        "type": "blacken",
        "path": "$.ssn",
        "discloseRight": 4
      }
    ]
  }
