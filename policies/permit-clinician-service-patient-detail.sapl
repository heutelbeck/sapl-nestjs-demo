policy "permit-clinician-service-patient-detail"
permit
  action == "service:getPatientDetail";
  resource.type == "patientDetail";
  <jwt.token>.payload.user_role == "CLINICIAN";
obligation
  {
    "type": "filterJsonContent",
    "actions": [
      {
        "type": "blacken",
        "path": "$.ssn",
        "replacement": "*",
        "discloseRight": 4
      }
    ]
  }
