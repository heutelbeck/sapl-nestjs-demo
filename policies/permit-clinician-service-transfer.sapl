policy "permit-clinician-service-transfer"
permit
  action == "service:transfer";
  resource == "account";
  <jwt.token>.payload.user_role == "CLINICIAN";
obligation
  {
    "type": "capTransferAmount",
    "maxAmount": 5000,
    "argIndex": 0
  }
obligation
  {
    "type": "logAccess",
    "message": "Fund transfer executed"
  }
