policy "permit-clinician-service-search-patients"
permit
  action == "service:searchPatients";
  resource == "patientSearch";
  <jwt.token>.payload.user_role == "CLINICIAN";
obligation
  {
    "type": "logAccess",
    "message": "Patient search query executed"
  }
obligation
  {
    "type": "filterByClassification",
    "maxLevel": "INTERNAL"
  }
